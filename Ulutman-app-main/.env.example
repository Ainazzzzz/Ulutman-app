# Database
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_jwt_secret_at_least_256_bits_long_base64_encoded

# Tigris / MinIO (S3-compatible)
AWS_ENDPOINT_URL=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=your_tigris_access_key_id
AWS_SECRET_ACCESS_KEY=your_tigris_secret_access_key
AWS_S3_BUCKET_NAME=ulutman-images
AWS_DEFAULT_REGION=auto

# Google OAuth2 (не нужен — авторизация через Firebase на фронте)